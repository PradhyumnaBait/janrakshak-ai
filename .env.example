# --- Database Configuration ---
# For local development, SQLite works great. Uncomment below:
DATABASE_URL=sqlite:///./civic_ai_shield.db

# For production with Supabase, use the connection string below:
# GET THIS FROM SUPABASE: Settings -> Database -> Connection string -> URI
# DATABASE_URL=postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Security & JWT ---
JWT_SECRET_KEY=your-very-secret-jwt-key  # Change this to a random long string in production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- AI API Keys ---
# Get this from Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-here

# Optional if you are strictly using Gemini now
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Server Configuration ---
# Your explicit localhost ports are fine, but you can also just use "*" for local dev testing
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
MAX_UPLOAD_SIZE_MB=20

# --- Frontend Configuration ---
NEXT_PUBLIC_API_URL=http://localhost:8000
